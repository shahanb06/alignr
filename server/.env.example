# Copy this file to .env and fill in real values.
# .env should be gitignored. Never commit your real key.

# Anthropic API key — server-side only. Never expose to the frontend.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the Express server listens on.
PORT=8787

# Origin of the Vite dev frontend, used for CORS.
# In production set this to your deployed frontend origin.
CLIENT_ORIGIN=http://localhost:5173

# Claude model. Pinned to the recommended Sonnet for this project.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-IP requests per hour for /api/tailor and /api/extract-resume.
RATE_LIMIT_PER_HOUR=25
